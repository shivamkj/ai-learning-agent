{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.ts",
    "format": "prettier . --write --list-different",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^8.1.0",
    "@langchain/core": "^1.2.2",
    "@langchain/openai": "^1.5.5",
    "@llamaindex/llama-cloud": "^2.11.0",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.10.0",
    "langchain": "^1.5.3",
    "nanoid": "^5.1.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  },
  "prettier": {
    "$schema": "http://json.schemastore.org/prettierrc",
    "trailingComma": "none",
    "tabWidth": 2,
    "printWidth": 120,
    "semi": false,
    "singleQuote": true
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
